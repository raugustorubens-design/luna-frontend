# URL pública do backend LUNA (Gateway + /api/chat). Sem isso, o Forge usa o
# default http://localhost:3001/api, que só existe em desenvolvimento local.
NEXT_PUBLIC_LUNA_API_BASE_URL=http://localhost:3001/api

# Opcional — diretório de trabalho do terminal/git-status locais do Forge.
# Default: process.cwd() (o próprio diretório do deploy), já correto na
# maioria dos casos.
# FORGE_WORKING_DIRECTORY=

# Obrigatória em produção para o terminal do Forge funcionar — sem ela, o
# servidor rejeita toda conexão em /forge/terminal (nenhum shell é criado).
# Em desenvolvimento local (NODE_ENV != production) não é exigida. As duas
# variáveis abaixo devem ter o MESMO valor: uma é lida pelo servidor
# (server.ts), a outra é exposta ao client para ele enviar o token na
# conexão WebSocket. Trate como um segredo — não é autenticação real, é o
# controle mínimo apropriado para este MVP (ver server.ts).
# FORGE_TERMINAL_TOKEN=
# NEXT_PUBLIC_FORGE_TERMINAL_TOKEN=

# Injetada automaticamente pelo Railway — não definir manualmente em produção.
# PORT=3000
