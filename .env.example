# URL pública do backend LUNA (Gateway + /api/chat). Sem isso, o Forge usa o
# default http://localhost:3001/api, que só existe em desenvolvimento local.
NEXT_PUBLIC_LUNA_API_BASE_URL=http://localhost:3001/api

# Opcional — diretório de trabalho do terminal/git-status locais do Forge.
# Default: process.cwd() (o próprio diretório do deploy), já correto na
# maioria dos casos.
# FORGE_WORKING_DIRECTORY=

# Injetada automaticamente pelo Railway — não definir manualmente em produção.
# PORT=3000
